<body>
    <div class="demo-wrapper">
        <!-- Phone Container (Left) -->
        <div class="phone-container">
            <div class="header">
                <div>
                    <div class="header-title">🎓 GapSense Teacher</div>
                    <div class="header-subtitle">AI Teaching Assistant</div>
                </div>
                <div class="status-badge" id="statusBadge">Demo Mode</div>
            </div>

            <div class="quick-actions">
                <button class="quick-btn" onclick="sendQuickMessage('/STATUS')">📊 Status</button>
                <button class="quick-btn" onclick="sendQuickMessage('/GAPS')">📍 Gaps</button>
                <button class="quick-btn" onclick="openReports()">📑 Reports</button>
                <button class="quick-btn" onclick="sendQuickMessage('START')">🚀 Start</button>
            </div>

            <div class="messages" id="messages">
                <div class="message received">
                    <div>
                        <div class="message-bubble">
                            Welcome to GapSense! 👋<br><br>
                            I'm your AI teaching assistant for identifying student gaps.<br><br>
                            Send <strong>START</strong> to begin onboarding or upload an exercise book photo!
                        </div>
                        <div class="message-time">Just now</div>
                    </div>
                </div>
            </div>

            <div class="input-area">
                <div class="input-wrapper">
                    <input type="file" id="imageInput" accept="image/*" capture="environment" style="display: none" onchange="handleImageSelect()">
                    <button class="icon-btn secondary" onclick="document.getElementById('imageInput').click()">
                        📎
                    </button>
                    <textarea
                        id="messageInput"
                        placeholder="Type a message..."
                        rows="1"
                        onkeydown="handleKeyDown(event)"
                    ></textarea>
                </div>
                <button class="icon-btn" onclick="sendMessage()">
                    ➤
                </button>
            </div>
        </div>

        <!-- Slideshow Container (Right) -->
        <div class="slideshow-container">
            <div class="slideshow-header">
                <div class="slideshow-title">How GapSense Works</div>
                <button class="expand-btn" onclick="openFullscreen()" title="Expand to fullscreen">
                    ⛶
                </button>
            </div>

            <div class="slides-area" id="slidesArea">
                <button class="slide-nav prev" onclick="changeSlide(-1)">‹</button>
                <button class="slide-nav next" onclick="changeSlide(1)">›</button>

                <div class="slides-track" id="slidesTrack">
                    <!-- Slide 1: Cover -->
                    <div class="slide">
                        <h1 style="font-size: 56px; margin-bottom: 16px;">GapSense</h1>
                        <p class="highlight" style="font-size: 24px; margin-bottom: 32px;">AI-Powered Learning Gap Diagnostics for Ghana</p>
                        <p style="font-size: 18px; max-width: 500px;">Empowering teachers to identify and close foundational math gaps through WhatsApp</p>
                        <div style="margin-top: 48px; padding: 16px; background: rgba(37, 211, 102, 0.1); border-radius: 12px; max-width: 400px; margin-left: auto; margin-right: auto;">
                            <p style="font-size: 16px; font-weight: 600; color: #25D366; margin-bottom: 4px;">UNICEF StartUp Lab Cohort 6</p>
                            <p class="caption" style="margin: 0;">Application • March 2026</p>
                        </div>
                    </div>

                    <!-- Slide 2: The Crisis -->
                    <div class="slide">
                        <h2>Ghana's Hidden Learning Crisis</h2>
                        <div class="stat">84%</div>
                        <p style="font-size: 18px; margin-bottom: 8px;">Of children aged 7-14 lack foundational numeracy</p>
                        <p class="caption" style="margin-bottom: 32px;">UNICEF MICS 2023</p>

                        <div style="display: flex; gap: 32px; justify-content: center; margin-bottom: 32px;">
                            <div>
                                <p class="number-pill">&lt;25%</p>
                                <p style="font-size: 16px; margin-top: 8px;">Primary 4 at math level</p>
                            </div>
                            <div>
                                <p class="number-pill">55%</p>
                                <p style="font-size: 16px; margin-top: 8px;">Have misconceptions</p>
                            </div>
                        </div>

                        <div style="background: rgba(232, 185, 35, 0.1); padding: 24px; border-radius: 12px; border-left: 4px solid #E8B923; max-width: 550px; margin: 0 auto;">
                            <p style="font-size: 20px; font-style: italic; line-height: 1.5; color: #2C3E50; margin: 0;">"Teachers know students are struggling, but can't pinpoint which foundational skills are missing."</p>
                        </div>
                    </div>

                    <!-- Slide 3: Root Problem -->
                    <div class="slide">
                        <h2>Why Current Solutions Fail</h2>
                        <div class="card-grid">
                            <div class="card">
                                <div class="card-title">❌ No Diagnostic Tools</div>
                                <div class="card-body">
                                    <p style="margin-bottom: 8px;">• No way to assess foundational gaps</p>
                                    <p style="margin: 0;">• Paper tests take weeks to analyze</p>
                                </div>
                            </div>
                            <div class="card">
                                <div class="card-title">❌ No Teacher Support</div>
                                <div class="card-body">
                                    <p style="margin-bottom: 8px;">• 120K+ teachers lack training</p>
                                    <p style="margin: 0;">• Class sizes of 40+ students</p>
                                </div>
                            </div>
                            <div class="card">
                                <div class="card-title">❌ No Parent Involvement</div>
                                <div class="card-body">
                                    <p style="margin-bottom: 8px;">• Parents don't know child's gaps</p>
                                    <p style="margin: 0;">• Language barriers to resources</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Slide 4: Solution -->
                    <div class="slide">
                        <h2>The GapSense Solution</h2>
                        <p style="font-size: 18px; margin-bottom: 30px;">AI-Powered Gap Diagnostics via WhatsApp</p>
                        <div style="display: flex; justify-content: space-around; align-items: center; margin: 30px 0;">
                            <div>
                                <p style="font-size: 40px;">📸</p>
                                <p style="font-size: 14px; font-weight: 600;">Teacher Uploads</p>
                                <p style="font-size: 12px;">Exercise book photo</p>
                                <p style="font-size: 12px; color: #E8B923;">30 seconds</p>
                            </div>
                            <p style="font-size: 30px; color: #25D366;">→</p>
                            <div>
                                <p style="font-size: 40px;">🤖</p>
                                <p style="font-size: 14px; font-weight: 600;">AI Analyzes</p>
                                <p style="font-size: 12px;">Ghana curriculum</p>
                                <p style="font-size: 12px; color: #E8B923;">8 seconds</p>
                            </div>
                            <p style="font-size: 30px; color: #25D366;">→</p>
                            <div>
                                <p style="font-size: 40px;">📊</p>
                                <p style="font-size: 14px; font-weight: 600;">Report Generated</p>
                                <p style="font-size: 12px;">Gap profile</p>
                                <p style="font-size: 12px; color: #E8B923;">Instant</p>
                            </div>
                        </div>
                        <p style="font-size: 14px; margin-top: 20px;">✅ No app download  |  ✅ Works offline  |  ✅ Local languages  |  ✅ Free for public schools</p>
