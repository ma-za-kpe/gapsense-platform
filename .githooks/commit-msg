#!/bin/sh
set -eu

message_file=$1
subject=$(head -n 1 "$message_file")
pattern='^(feat|fix|docs|test|refactor|perf|build|ci|chore|revert)(\([a-z0-9._/-]+\))?!?: .{1,72}$'

if ! printf '%s\n' "$subject" | grep -Eq "$pattern"; then
  echo "Commit subject must use Conventional Commits, with a 1-72 character description." >&2
  echo "Example: feat(web): add fail-closed readiness endpoint" >&2
  exit 1
fi

if [ "${#subject}" -gt 100 ]; then
  echo "Commit subject exceeds 100 characters." >&2
  exit 1
fi
