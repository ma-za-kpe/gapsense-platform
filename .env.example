# GapSense local Docker overrides
#
# Docker Compose supplies safe local defaults. Copy this file to `.env` only
# when you need to select a different locally installed Ollama model.

OLLAMA_MODEL=llama3.1:8b

# The web container reaches the host Ollama service through Docker Desktop.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# The sibling gapsense-data repository is mounted read-only at /app/data.
GAPSENSE_DATA_PATH=/app/data

# Host-side Compose source. Keep the sibling data repository as the local default.
# Hosted CI overrides this with the committed synthetic public fixture.
GAPSENSE_DATA_HOST_PATH=../gapsense-data
