{
  "name": "gapsense-frontend",
  "version": "1.0.0",
  "description": "GapSense - AI-Powered Learning Gap Diagnostics for Ghana (Mobile-First Frontend)",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "analyze": "vite-bundle-visualizer",
    "lint:css": "stylelint 'frontend/**/*.css'",
    "lint:js": "eslint 'frontend/**/*.js'",
    "lint": "npm run lint:js && npm run lint:css && npm run type-check",
    "format": "prettier --write 'frontend/**/*.{js,css,json,md}'"
  },
  "dependencies": {},
  "devDependencies": {
    "vite": "^5.0.0",
    "terser": "^5.26.0",
    "typescript": "^5.3.0",
    "vite-bundle-visualizer": "^1.0.0",
    "@types/node": "^20.10.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "education",
    "ghana",
    "mobile-first",
    "pwa",
    "offline-first",
    "3g-optimized"
  ],
  "author": "GapSense Team",
  "license": "UNLICENSED"
}
