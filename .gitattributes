.gitattributes text eol=lf
*.sh text eol=lf
.githooks/* text eol=lf
Dockerfile text eol=lf
*.py text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
frontend/** text eol=lf
frontend/**/*.png binary
